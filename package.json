{
  "name": "example4",
  "version": "0.1.1",
  "description": "Example 4 dapplet",
  "main": "lib/index.js",
  "scripts": {
    "start": "rollup -w --config rollup.config.js",
    "start-html": "concurrently -c \"yellow,green\" -n \"dapplet,overlay\" \"rollup -w --config rollup.config.js\" \"cd pure-html-page && npx serve -l 3000\"",
    "start-react": "concurrently -c \"yellow,blue\" -n \"dapplet,overlay\" \"rollup -w --config rollup.config.js\" \"cd overlayWithReact && npm start\"",
    "build": "rollup --config rollup.config.js"
  },
  "cacheDirectories": [
    "node_modules",
    "overlayWithReact/node_modules"
  ],
  "author": "Dapplets Project",
  "license": "MIT",
  "devDependencies": {
    "@dapplets/dapplet-extension": "latest",
    "@rollup/plugin-commonjs": "^17.1.0",
    "@rollup/plugin-image": "^2.0.6",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^11.1.1",
    "@rollup/plugin-typescript": "^8.1.1",
    "concurrently": "^6.0.0",
    "rollup": "^2.38.3",
    "rollup-plugin-serve": "^1.1.0",
    "tslib": "^2.1.0",
    "typescript": "^4.1.3"
  },
  "dependencies": {}
}
